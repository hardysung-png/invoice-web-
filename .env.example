# Notion API 설정
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 관리자 인증
ADMIN_PASSWORD=your-strong-password-here
SESSION_SECRET=your-32-character-or-longer-session-secret-here

# Slack 알림 (선택사항)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# 크론 잡 인증 시크릿 (최소 16자, Vercel Cron 호출 인증에 사용)
CRON_SECRET=your-cron-secret-min-16-chars

# 앱 URL (선택사항)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
